# Database
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/postgres

# Frontend
# Optional when running the frontend outside Docker. The Dockerized frontend
# uses an internal reverse proxy and does not need this.
VITE_API_BASE_URL=

# External AI provider for the optional AI endpoints.
# AI_PROVIDER supports: ollama, openai
# For Ollama use the server root URL, for example http://gpu-server:11434
# For OpenAI use the server root URL, for example https://api.openai.com
AI_PROVIDER=ollama
AI_BASE_URL=http://localhost:11434
AI_API_KEY=
AI_CHAT_MODEL=qwen3.5:9b