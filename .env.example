# Database
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/postgres

# Frontend
# Optional when running the frontend outside Docker. The Dockerized frontend
# uses an internal reverse proxy and does not need this.
VITE_API_BASE_URL=

# External AI provider for the AI-assisted parsing and message endpoints.
# Select one active provider at a time.
#
# Minimal Ollama setup:
# AI_PROVIDER=ollama
# AI_BASE_URL=http://localhost:11434
# AI_CHAT_MODEL=qwen3.5:9b
#
# Minimal OpenAI/OpenRouter-style setup:
# AI_PROVIDER=openai-compatible
# AI_BASE_URL=https://api.openai.com
# AI_API_KEY=your-api-key
# AI_CHAT_MODEL=gpt-4.1-mini
#
# Notes:
# - AI_PROVIDER supports: ollama, openai-compatible
# - AI_API_KEY is ignored for ollama
# - AI_CHAT_MODEL is still needed for both providers because the backend must know which chat model to call
AI_PROVIDER=ollama
AI_BASE_URL=http://localhost:11434
AI_API_KEY=
AI_CHAT_MODEL=qwen3.5:9b