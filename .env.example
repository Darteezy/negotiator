# Database
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/postgres

# Frontend
# Optional when running the frontend outside Docker. The Dockerized frontend
# uses an internal reverse proxy and does not need this.
VITE_API_BASE_URL=

# For backend runs outside Docker. Docker Compose defaults to http://ollama:11434.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3.5:9b